# Transport configuration (stdio or sse)
MCP_TRANSPORT=stdio

# Server configuration
PORT=8000
HOST=0.0.0.0

# Security (Optional)
# If set, all SSE requests must provide this key in 'X-API-Key' header or 'api_key' query param
API_KEY=your_secure_api_key_here

# Add your API keys here
# NWS_API_USER_AGENT=nextgen-mcp/1.0
