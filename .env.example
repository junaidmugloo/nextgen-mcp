# Transport configuration (stdio or sse)
MCP_TRANSPORT=stdio

# Server configuration
PORT=8000
HOST=0.0.0.0

# Security (Optional)
# If set, all SSE requests must provide these in headers or query params
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret

# Add your API keys here
# NWS_API_USER_AGENT=nextgen-mcp/1.0
